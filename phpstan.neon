parameters:
  level: 1
  scanDirectories:
    - state
    - dependencies
  paths:
    - src
    - tests
  earlyTerminatingMethodCalls:
    Valvoid\Fusion\Hub\Requests\Remote\Remote:
      - throwError
    Valvoid\Fusion\Config\Logic:
      - throwMetaError
    Valvoid\Fusion\Box\Box:
      - throwNormalizedError